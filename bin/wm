#!/usr/bin/env bash
# Watchman CLI wrapper — runs via Mix to support NIF dependencies (exqlite)
set -e

# Resolve symlinks to find actual project directory
REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")/.." && pwd)"
cd "$SCRIPT_DIR"

export MIX_ENV="${MIX_ENV:-prod}"
exec mix run -e "Watchman.CLI.main(System.argv())" -- "$@"
